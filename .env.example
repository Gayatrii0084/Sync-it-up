# ─── Server ────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── MongoDB ───────────────────────────────
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/syncitup?retryWrites=true&w=majority

# ─── Session ───────────────────────────────
# Generate a long random string. Example: openssl rand -hex 32
SESSION_SECRET=replace_with_a_strong_random_secret_key

# ─── Email (for OTP) ───────────────────────
# Use a Gmail account with App Password (not your main password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── CORS (optional for separate deployment) ─
# Set to the frontend URL if hosting frontend separately from the backend
# Leave blank or same as backend URL if using unified Render deployment
ALLOWED_ORIGIN=https://your-app-name.onrender.com
